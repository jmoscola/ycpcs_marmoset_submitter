#########################################################
# marmoset_submitter.properties
#########################################################
# Copy this file to the root directory of your project
# and rename it to "marmoset_submitter.properties".
# Fill in the values below to configure the
# YCPCS Marmoset Submitter IntelliJ plugin.
#########################################################


#########################################################
# REQUIRED SETTINGS
#########################################################

# The URL of the Marmoset submission server. This value
# is provided by your instructor and should not be changed
# unless directed to do so.
submissionUrl=https://cs.ycp.edu/marmoset/bluej/SubmitProjectViaBlueJSubmitter

# The name of the CMake assignment info file in the root
# directory of your project. This file contains the course
# name, term, and project number required for submission.
# The file must follow the format shown below:
#
#   set(COURSE_NAME "CS 350")
#   set(TERM "Fall")
#   string(TIMESTAMP CURRENT_YEAR "%Y")
#   set(SEMESTER "${TERM} ${CURRENT_YEAR}")
#   set(PROJECT_NUMBER "assign01")
#   set(PROJECT_NAME_STR IntArrayStack)
#
# Notes:
#   - COURSE_NAME must match the course name in Marmoset exactly.
#   - TERM must be "Fall", "Spring", or "Summer".
#   - PROJECT_NUMBER must match the assignment name in Marmoset exactly.
#   - SEMESTER and PROJECT_NAME_STR are not used by the plugin
#     but are required by the CMake build system.
#   - Values may be quoted or unquoted.
assignmentInfoFilename=CMakeLists.assignment_info.txt


#########################################################
# FILE INCLUSION RULES
#########################################################

# Comma-separated whitelist of exact filenames to include
# in the submission zip file
#
# Example: allowedFilenames=main.cpp,main.h,Makefile
#
# When set to one or more values, only files whose names
# appear in this list will be included, regardless of
# their extension. This is a more restrictive filter than
# allowedExtensions, when both are set, a file must
# satisfy both filters to be included.
#
# When omitted entirely from this file, all filenames are
# considered for inclusion, subject to the other rules.
#
# IMPORTANT: If this property is present but left empty
# (i.e. allowedFilenames=), it is treated as an empty
# set and no files will be included in the zip file,
# resulting in an empty submission.
#allowedFilenames=

# Comma-separated whitelist of file extensions to include
# in the submission zip file, without leading dots
#
# Example: allowedExtensions=h,cpp
#          allowedExtensions=java
#          allowedExtensions=h,cpp,java
#
# When set to one or more values, only files whose
# extensions appear in this list will be included. Files
# with any other extension will be excluded regardless of
# their location in the project.
#
# When omitted entirely from this file, files of all
# extensions are considered for inclusion, subject to the
# other exclusion rules below.
#
# IMPORTANT: If this property is present but left empty
# (i.e. allowedExtensions=), it is treated as an empty
# set and no files will be included in the zip file,
# resulting in an empty submission.
allowedExtensions=h,cpp


#########################################################
# FILE EXCLUSION RULES
#########################################################

# Comma-separated list of file extensions to
# unconditionally exclude from the submission zip file,
# without leading dots
#
# Example: excludedExtensions=o,d,a,log,exe,zip
#
# Any file whose extension appears in this list will be
# excluded regardless of its location in the project
# directory tree. Useful for excluding build artifacts
# and other generated files that should not be submitted.
excludedExtensions=o,d,a,iml,log,stackdump,exe,zip,pl

# Comma-separated list of exact filenames to
# unconditionally exclude from the submission zip file
#
# Example: excludedFilenames=.DS_Store,Flags.h,tests.cpp
#
# Any file whose name appears in this list will be
# excluded regardless of its location in the project
# directory tree. Useful for excluding instructor-provided
# files that students should not modify or submit.
excludedFilenames=.DS_Store,marmoset_submitter.properties,Flags.h,tests.cpp

# Comma-separated list of directory names to exclude from
# the submission zip file
#
# Example: excludedDirectories=.git,.idea,build,out
#
# When a directory name appears in this list, the
# directory will not be recursed. Neither the directory
# itself nor any of its contents will be included in the
# submission, regardless of the other inclusion rules.
excludedDirectories=.git,.idea,.vs,.gradle,build,out,target,node_modules,cmake-build-debug


#########################################################
# OTHER SETTINGS
#########################################################

# The suffix appended to the project number to form the
# zip filename. For example, a project number of "assign01"
# and a suffix of "_submission" produces a zip file named
# "assign01_submission.zip".
#
# This property is optional. If omitted, the suffix
# defaults to "_submission".
zipFilenameSuffix=_submission

# Specifies whether the submission year should be read from the
# CMakeLists.assignment_info.txt file or determined automatically
# from the current system year.
#
# Set to 'true' to read the year from the assignment info file.
# In this case, the assignment info file must contain a line like:
#   set(YEAR "2026")
#
# Set to 'false' (or omit entirely) to use the current system year
# automatically via java.time.Year.now().
#
# Default: false (use system year)
useAssignmentInfoYear=false
