<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.jmoscola.ycpcsmarmosetsubmitter</id>
    <name>ycpcs_marmoset_submitter</name>
    <vendor>jmoscola</vendor>

    <description>
        Plugin for submitting assignments to YCPCS Marmoset.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.SubmitterBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
    </extensions>

    <actions>
        <action
                id="org.example.yourplugin.LoginAction"
                class="com.github.jmoscola.ycpcsmarmosetsubmitter.actions.LoginAction"
                text="Submit to Marmoset"
                description="Submit assignment to Marmoset"
                icon="/icons/ycpcs_marmoset_submitter.svg">
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <!-- the following adds to the right click menu, when right-clicking in editor window -->
            <!-- <add-to-group group-id="EditorPopupMenu" anchor="last"/> -->
        </action>
    </actions>
</idea-plugin>
